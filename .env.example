# Required for auth, saved builds, and other community features
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: canonical public site origin for auth redirects, share links, and metadata
PUBLIC_SITE_URL=https://www.tyrhq.com

# Optional: enables API key generation / revocation in /settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
