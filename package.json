{
	"name": "aggrowebsite",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"prepare": "svelte-kit sync || echo ''",
		"export:data": "python scripts/export_data.py",
		"export:data:dry": "python scripts/export_data.py --dry-run --verbose",
		"sync:data": "python scripts/export_data.py --generated-out GameData/generated --vehicle-images-dir GameData/assets/images/vehicles --map-lobby-dir GameData/assets/images/maps/lobby --map-minimap-dir GameData/assets/images/maps/minimap --ammo-icons-dir GameData/assets/images/ammo --component-icons-dir GameData/assets/images/components --talent-icons-dir GameData/assets/images/talents --ui-icons-dir GameData/assets/images/icons --armor-models-dir GameData/assets/models/vehicles --skip-canonical",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/three": "^0.184.0",
		"mdsvex": "^0.12.7",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vite-plugin-static-copy": "^4.1.0",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.104.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@threlte/core": "^8.5.9",
		"@threlte/extras": "^9.14.9",
		"fast-xml-parser": "^5.7.2",
		"swagger-ui-dist": "^5.32.4",
		"three": "^0.184.0",
		"zod": "^4.3.6"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.2"
		},
		"picomatch": "^4.0.4"
	}
}
